# 1. Anthropic API Key → https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-VENDOS-KETU-CELESIN-TEND

# 2. WordPress URL (pa / dhe pa /wp-admin në fund)
WP_URL=https://politiplot.com

# 3. WordPress Username
WP_USER=admin

# 4. WordPress Application Password
#    Dashboard → Users → Profile → Application Passwords
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
